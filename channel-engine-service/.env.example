# Channel Engine Service Configuration
# Copy this file to .env and update values for your environment

# ============================================================
# CHANNEL_ENGINE_PATH (Required)
# ============================================================
# This must be a LOCAL filesystem path to your ChannelEngine clone.
# NOT a GitHub URL!
#
# Setup steps:
#   1. Clone the repository:
#      git clone https://github.com/swang430/ChannelEgine.git /path/to/ChannelEgine
#
#   2. Set the path below to your local clone directory:
#
# Examples:
#   macOS:   /Users/yourname/Projects/ChannelEgine
#   Linux:   /home/yourname/ChannelEgine
#   Windows: C:\Users\yourname\ChannelEgine
#
CHANNEL_ENGINE_PATH=/path/to/your/local/ChannelEgine

# ============================================================
# Server configuration (Optional)
# ============================================================
# HOST=0.0.0.0
# PORT=8001
