      }
    },
    "/api/v1/ota/generate-probe-weights": {
      "post": {
        "tags": [
          "OTA\u63a2\u5934\u6743\u91cd"
        ],
        "summary": "\u751f\u6210\u63a2\u5934\u6743\u91cd",
        "description": "\u57fa\u4e8e3GPP\u4fe1\u9053\u6a21\u578b\u548c\u63a2\u5934\u9635\u5217\u914d\u7f6e\uff0c\u8ba1\u7b97OTA\u6d4b\u8bd5\u6240\u9700\u7684\u63a2\u5934\u6743\u91cd",
        "operationId": "generate_probe_weights_api_v1_ota_generate_probe_weights_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProbeWeightRequest"
              }
