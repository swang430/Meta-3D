# Application Configuration
APP_NAME=Meta-3D OTA API
APP_VERSION=1.0.0
DEBUG=true

# Database
# PostgreSQL (Production)
DATABASE_URL=postgresql://meta3d:meta3d_password@localhost:5432/meta3d_ota

# SQLite (Development)
# DATABASE_URL=sqlite:///./meta3d_ota.db

# API
API_V1_PREFIX=/api/v1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# Mock Instruments (set to false for real hardware)
USE_MOCK_INSTRUMENTS=true

# Calibration Settings
CALIBRATION_DATA_PATH=./calibration_data
CERTIFICATE_OUTPUT_PATH=./certificates
